# Required, set your Anthropic API key (Phase 2+).
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY

# Required for Socket Mode (local dev). Not needed when SLACK_TRANSPORT=http.
# SLACK_APP_TOKEN=YOUR_SLACK_APP_TOKEN
# SLACK_BOT_TOKEN=YOUR_SLACK_BOT_TOKEN

# Required for Railway / HTTP mode (SLACK_TRANSPORT=http).
# SLACK_SIGNING_SECRET=YOUR_SLACK_SIGNING_SECRET
# SLACK_TRANSPORT=http
# PORT=3000

# Required for Canvas creation via Slack MCP (Phase 1+).
# User OAuth Token from OAuth & Permissions - needs canvases:read + canvases:write.
# SLACK_USER_TOKEN=xoxp-...

# Required for Supabase (Phase 1+).
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Required for OAuth (app_oauth.py). Set your app's OAuth credentials.
# SLACK_CLIENT_ID=YOUR_SLACK_CLIENT_ID
# SLACK_CLIENT_SECRET=YOUR_SLACK_CLIENT_SECRET
# SLACK_REDIRECT_URI=https://YOUR_NGROK_SUBDOMAIN.ngrok-free.app/slack/oauth_redirect

# Optional: show "Simulate payment" on change order cards (demo). Set false for production.
# DEMO_MODE=true

# Optional Stripe Payment Link for change-order demo (Phase 4).
# STRIPE_PAYMENT_LINK_URL=https://buy.stripe.com/test_...

# Optional studio display name (studio report)
# STUDIO_NAME=Keystone Digital Studio
