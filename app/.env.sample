# ============================================================
# APP_MODE - single switch (preferred over SLACK_TRANSPORT)
#   dev  = local Socket Mode  →  python app.py on your laptop
#   prod = Railway HTTP       →  do NOT run local; use Railway
# Or: python scripts/switch_mode.py dev|prod
# ============================================================
APP_MODE=dev

# Required for scope classifier (Groq Llama 3.3 70B).
GROQ_API_KEY=YOUR_GROQ_API_KEY

# Required for brief extraction, reply drafting, mockup vision (Anthropic).
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY

# Required for Socket Mode (APP_MODE=dev).
# SLACK_APP_TOKEN=YOUR_SLACK_APP_TOKEN
# SLACK_BOT_TOKEN=YOUR_SLACK_BOT_TOKEN

# Required for Railway / HTTP (APP_MODE=prod). Railway also sets PORT.
# SLACK_SIGNING_SECRET=YOUR_SLACK_SIGNING_SECRET
# PORT=3000

# Required for Canvas, RTS, and posting client-facing replies/COs *as you*
# (not as the bot). For a single workspace, paste your User OAuth Token here.
# For distributed installs, app_oauth.py stores this automatically when the
# installer grants user scopes (chat:write, canvases:*, search:read, …).
# SLACK_USER_TOKEN=xoxp-...

# Required for Supabase (Phase 1+).
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Required for OAuth (app_oauth.py). Set your app's OAuth credentials.
# SLACK_CLIENT_ID=YOUR_SLACK_CLIENT_ID
# SLACK_CLIENT_SECRET=YOUR_SLACK_CLIENT_SECRET
# SLACK_REDIRECT_URI=https://YOUR_NGROK_SUBDOMAIN.ngrok-free.app/slack/oauth_redirect

# Optional: show "Simulate payment" on change order cards (demo). Set false for production.
# DEMO_MODE=true

# Optional Stripe Payment Link for change-order demo (Phase 4).
# STRIPE_PAYMENT_LINK_URL=https://buy.stripe.com/test_...

# Optional studio display name (studio report)
# STUDIO_NAME=Keystone Digital Studio
